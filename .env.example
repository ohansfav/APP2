# Intelligent Sports Management System - Environment Configuration
# Copy this file to .env and update with your actual values
# IMPORTANT: .env should NEVER be committed to version control

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
SERVER_NAME=localhost:8000

# Database Configuration
DATABASE_URI=sqlite:///sports_management.db
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ECHO=False

# Application Settings
APP_NAME=Athlete Performance Predictor
APP_VERSION=2.0.0
TIMEZONE=UTC

# Security
PROPAGATE_EXCEPTIONS=False
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=86400

# Authentication
LOGIN_REQUIRED=True
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-password-in-production

# Machine Learning Models
ML_MODEL_CONFIDENCE_THRESHOLD=0.75
INJURY_RISK_THRESHOLD=0.7

# Application Features
ENABLE_TRAINING_TRACKING=True
ENABLE_INJURY_TRACKING=True
ENABLE_TALENT_METRICS=True
ENABLE_EVENT_MANAGEMENT=True
ENABLE_ANALYTICS=True

# Performance & Optimization
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300
MAX_CONTENT_LENGTH=16777216
JSON_SORT_KEYS=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Development/Testing
TESTING=False
PRESERVE_CONTEXT_ON_EXCEPTION=False
